        <mxCell id="ihIEzpLeea8CW4s2Sm3f-41" value="&lt;pre style=&quot;background-color: rgb(30, 31, 34); font-size: 9.8pt; font-family: &amp;quot;JetBrains Mono&amp;quot;, monospace; color: rgb(188, 190, 196);&quot;&gt;&lt;div&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;div&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;private val &lt;/span&gt;&lt;span style=&quot;color:#c77dbb;font-style:italic;&quot;&gt;okChannel &lt;/span&gt;= &lt;br&gt;    &lt;span style=&quot;font-style:italic;&quot;&gt;MutableSharedFlow&lt;/span&gt;&amp;lt;Unit&amp;gt;(&lt;span style=&quot;color:#56c1d6;&quot;&gt;extraBufferCapacity = &lt;/span&gt;&lt;span style=&quot;color:#2aacb8;&quot;&gt;1&lt;/span&gt;)&lt;/pre&gt;&lt;/div&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;fun &lt;/span&gt;&lt;span style=&quot;color:#56a8f5;&quot;&gt;notifyOk&lt;/span&gt;() {&lt;br&gt;    &lt;span style=&quot;color:#c77dbb;font-style:italic;&quot;&gt;authSuccessChannel&lt;/span&gt;.tryEmit(Unit)&lt;br&gt;}&lt;/pre&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;br&gt;&lt;/pre&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;div&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;fun &lt;/span&gt;&lt;span style=&quot;color:#56a8f5;&quot;&gt;XxxxScaffoldViewController&lt;/span&gt;(&lt;br&gt;    onShowAlert: () -&amp;gt; Unit,&lt;br&gt;) = &lt;span style=&quot;font-style:italic;&quot;&gt;ComposeUIViewController &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;val &lt;/span&gt;viewModel: XxxxViewModel = &lt;span style=&quot;color:#6bb38a;&quot;&gt;koinViewModel&lt;/span&gt;()&lt;br&gt;&lt;br&gt;    &lt;span style=&quot;color:#6bb38a;&quot;&gt;LaunchedEffect&lt;/span&gt;(Unit) &lt;span style=&quot;font-weight:bold;&quot;&gt;{&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color:#c77dbb;font-style:italic;&quot;&gt;okChannel&lt;/span&gt;.collect &lt;span style=&quot;font-weight:bold;&quot;&gt;{&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;            &lt;/span&gt;viewModel.notifyOk()&lt;br&gt;        &lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;    }&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color:#6bb38a;&quot;&gt;XxxxScaffold&lt;/span&gt;(&lt;br&gt;        &lt;span style=&quot;color:#56c1d6;&quot;&gt;onShowAlert = &lt;/span&gt;onShowAlert&lt;br&gt;    )&lt;br&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;/span&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/pre&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;strokeColor=#000000;fillColor=#000000;verticalAlign=top;" vertex="1" parent="1">
