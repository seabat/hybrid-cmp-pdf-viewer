        <mxCell id="vd9MNSVJaQYSb5U541uR-24" value="&lt;div style=&quot;background-color:#1e1f22;color:#bcbec4&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;div&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;span style=&quot;color:#b3ae60;&quot;&gt;@Composable&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;fun &lt;/span&gt;&lt;span style=&quot;color:#56a8f5;&quot;&gt;XxxxScreen&lt;/span&gt;() {&lt;br&gt;    &lt;span style=&quot;color:#cf8e6d;&quot;&gt;val &lt;/span&gt;viewModel: XxxxViewModel = &lt;span style=&quot;color:#6bb38a;&quot;&gt;koinViewModel&lt;/span&gt;()&lt;br&gt;    &lt;span style=&quot;color:#cf8e6d;&quot;&gt;var &lt;/span&gt;showDialog &lt;span style=&quot;color:#cf8e6d;&quot;&gt;by &lt;/span&gt;&lt;span style=&quot;color:#6bb38a;&quot;&gt;remember &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{ &lt;/span&gt;&lt;span style=&quot;font-style:italic;&quot;&gt;mutableStateOf&lt;/span&gt;(&lt;span style=&quot;color:#cf8e6d;&quot;&gt;false&lt;/span&gt;) &lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color:#6bb38a;&quot;&gt;XxxxScaffold &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;        &lt;/span&gt;showDialog = &lt;span style=&quot;color:#cf8e6d;&quot;&gt;true&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;if &lt;/span&gt;(showDialog) {&lt;br&gt;        &lt;span style=&quot;color:#6bb38a;&quot;&gt;AlertDialog&lt;/span&gt;(&lt;br&gt;            &lt;span style=&quot;color:#56c1d6;&quot;&gt;onDismissRequest = &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{ &lt;/span&gt;showDialog = &lt;span style=&quot;color:#cf8e6d;&quot;&gt;false &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;/span&gt;,&lt;br&gt;            &lt;span style=&quot;color:#56c1d6;&quot;&gt;confirmButton = &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;                &lt;/span&gt;&lt;span style=&quot;color:#0da19e;&quot;&gt;TextButton&lt;/span&gt;(&lt;span style=&quot;color:#56c1d6;&quot;&gt;onClick = &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{ &lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;                    &lt;/span&gt;showDialog = &lt;span style=&quot;color:#cf8e6d;&quot;&gt;false&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;                    &lt;/span&gt;viewModel.notifyOk()&lt;br&gt;                &lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;/span&gt;) &lt;span style=&quot;font-weight:bold;&quot;&gt;{&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;                    &lt;/span&gt;&lt;span style=&quot;color:#6bb38a;&quot;&gt;Text&lt;/span&gt;(&lt;span style=&quot;color:#6aab73;&quot;&gt;&quot;&lt;/span&gt;&lt;span style=&quot;color:#6aab73;font-family:&#39;Menlo-Regular&#39;,monospace;&quot;&gt;アラート&lt;/span&gt;&lt;span style=&quot;color:#6aab73;&quot;&gt;&quot;&lt;/span&gt;)&lt;br&gt;                &lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;            }&lt;/span&gt;,&lt;br&gt;            &lt;span style=&quot;color:#56c1d6;&quot;&gt;text = &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{ &lt;/span&gt;&lt;span style=&quot;color:#6bb38a;&quot;&gt;Text&lt;/span&gt;(&lt;span style=&quot;color:#6aab73;&quot;&gt;&quot;OK&quot;&lt;/span&gt;) &lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;        &lt;/span&gt;)&lt;br&gt;    }&lt;br&gt;}&lt;/pre&gt;&lt;/div&gt;&lt;/pre&gt;&lt;/pre&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;strokeColor=#000000;fillColor=#000000;" vertex="1" parent="1">
