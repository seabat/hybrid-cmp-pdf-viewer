        <mxCell id="vd9MNSVJaQYSb5U541uR-15" value="&lt;div style=&quot;background-color:#1e1f22;color:#bcbec4&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;div&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;span style=&quot;color:#b3ae60;&quot;&gt;@Composable&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;fun &lt;/span&gt;&lt;span style=&quot;color:#56a8f5;&quot;&gt;XxxxScreen&lt;/span&gt;() {&lt;br&gt;    &lt;span style=&quot;color:#cf8e6d;&quot;&gt;var &lt;/span&gt;showDialog &lt;span style=&quot;color:#cf8e6d;&quot;&gt;by &lt;/span&gt;&lt;span style=&quot;color:#6bb38a;&quot;&gt;remember &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{ &lt;/span&gt;&lt;span style=&quot;font-style:italic;&quot;&gt;mutableStateOf&lt;/span&gt;(&lt;span style=&quot;color:#cf8e6d;&quot;&gt;false&lt;/span&gt;) &lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color:#6bb38a;&quot;&gt;XxxxScaffold &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;        &lt;/span&gt;showDialog = &lt;span style=&quot;color:#cf8e6d;&quot;&gt;true&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;if &lt;/span&gt;(showDialog) {&lt;br&gt;        &lt;span style=&quot;color:#6bb38a;&quot;&gt;AlertDialog&lt;/span&gt;(&lt;br&gt;            &lt;span style=&quot;color:#56c1d6;&quot;&gt;onDismissRequest = &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{ &lt;/span&gt;showDialog = &lt;span