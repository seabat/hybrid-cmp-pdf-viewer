        <mxCell id="8cStw-i6LV4fzoyZ9DAJ-13" value="&lt;div style=&quot;background-color: rgb(30, 31, 34); color: rgb(188, 190, 196);&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;span style=&quot;color:#b3ae60;&quot;&gt;@Composable&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#cf8e6d;&quot;&gt;fun &lt;/span&gt;&lt;span style=&quot;color:#56a8f5;&quot;&gt;ScreenScaffold&lt;/span&gt;() {&lt;br&gt;    &lt;span style=&quot;color:#6bb38a;&quot;&gt;Scaffold&lt;/span&gt;(&lt;br&gt;        &lt;span style=&quot;color:#56c1d6;&quot;&gt;containerColor = &lt;/span&gt;Color.Green,  &lt;span style=&quot;color:#7a7e85;&quot;&gt;// &lt;/span&gt;&lt;span style=&quot;color:#7a7e85;font-family:&#39;Menlo-Regular&#39;,monospace;&quot;&gt;端末最下部のナビゲーションバーの背景&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color:#7a7e85;font-family:&#39;Menlo-Regular&#39;,monospace;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color:#56c1d6;&quot;&gt;topBar = &lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;{&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-weight:bold;&quot;&gt;            &lt;/span&gt;TopAppBar&lt;span style=&quot;font-size: 9.8pt; white-space: normal;&quot;&gt;(&lt;/span&gt;title = &lt;span style=&quot;font-size: 9.8pt; white-space: normal; font-weight: bold;&quot;&gt;{ &lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal; color: rgb(107, 179, 138);&quot;&gt;Text&lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal; color: rgb(106, 171, 115);&quot;&gt;&quot;PDF &lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal; color: rgb(106, 171, 115); font-family: Menlo-Regular, monospace;&quot;&gt;ビューア&lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal; color: rgb(106, 171, 115);&quot;&gt;&quot;&lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal; font-weight: bold;&quot;&gt;})&lt;br&gt;&lt;/span&gt;        &lt;span style=&quot;font-weight:bold;&quot;&gt;}&lt;br&gt;&lt;/span&gt;&lt;div&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;&lt;pre style=&quot;font-family:&#39;JetBrains Mono&#39;,monospace;font-size:9.8pt;&quot;&gt;) { padding -&amp;gt;&lt;br&gt;    &lt;span style=&quot;color:#0da19e;&quot;&gt;Box&lt;/span&gt;(&lt;br&gt;       modifier = &lt;span style=&quot;font-size: 9.8pt; white-space: normal;&quot;&gt;modifier.&lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal; color: rgb(87, 170, 247); font-style: italic;&quot;&gt;background&lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal; color: rgb(86, 193, 214);&quot;&gt;color =&amp;nbsp;&lt;/span&gt;Color.Green),&lt;span style=&quot;font-size: 9.8pt; white-space: normal; color: rgb(86, 193, 214);&quot;&gt;&lt;br&gt;&lt;/span&gt;       contentAlignment = &lt;span style=&quot;font-size: 9.8pt; white-space: normal;&quot;&gt;Alignment.&lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal; color: rgb(199, 125, 187);&quot;&gt;Center&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt; white-space: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; ) &lt;/span&gt;&lt;span style=&quot;font-size: 9.8pt;&quot;&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;b&gt;{&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&quot;white-space: normal;&quot;&gt;&lt;b&gt;&lt;/b&gt;&lt;/span&gt;        &lt;span style=&quot;font-size: 9.8pt; white-space: normal; color: rgb(107, 179, 138);&quot;&gt;Text&lt;/span