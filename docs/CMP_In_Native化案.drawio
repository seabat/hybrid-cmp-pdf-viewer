        <mxCell id="vd9MNSVJaQYSb5U541uR-27" value="&lt;pre style=&quot;color: rgb(188, 190, 196); font-size: 9.8pt; background-color: rgb(30, 31, 34); font-family: &amp;quot;JetBrains Mono&amp;quot;, monospace;&quot;&gt;&lt;span style=&quot;color: rgb(179, 174, 96);&quot;&gt;@Composable&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;fun &lt;/span&gt;&lt;span style=&quot;color: rgb(86, 168, 245);&quot;&gt;XxxxScaffold&lt;/span&gt;(onShowAlert: () -&amp;gt; Unit) {&lt;br&gt;    &lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;val &lt;/span&gt;viewModel: XxxxViewModel = &lt;span style=&quot;color: rgb(107, 179, 138);&quot;&gt;koinViewModel&lt;/span&gt;()&lt;br&gt;    &lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;val &lt;/span&gt;ok &lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;by &lt;/span&gt;viewModel.&lt;span style=&quot;color: rgb(199, 125, 187);&quot;&gt;ok&lt;/span&gt;.&lt;span style=&quot;color: rgb(107, 179, 138);&quot;&gt;collectAsStateWithLifecycle&lt;/span&gt;()&lt;br&gt;    &lt;span style=&quot;color: rgb(107, 179, 138);&quot;&gt;Text&lt;/span&gt;(&lt;br&gt;        &lt;span style=&quot;color: rgb(86, 193, 214);&quot;&gt;modifier = &lt;/span&gt;Modifier.&lt;span style=&quot;color: rgb(87, 170, 247); font-style: italic;&quot;&gt;clickable&lt;/span&gt;&lt;span style=&quot;font-weight: bold;&quot;&gt;{ &lt;/span&gt;onShowAlert() &lt;span style=&quot;font-weight: bold;&quot;&gt;}&lt;/span&gt;,&lt;br&gt;        &lt;span style=&quot;color: rgb(86, 193, 214);&quot;&gt;text = &lt;/span&gt;&lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;if &lt;/span&gt;(ok) { &lt;span style=&quot;color: rgb(106, 171, 115);&quot;&gt;&quot;Hello, World!&quot; &lt;/span&gt;} &lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;else &lt;/span&gt;{ &lt;span style=&quot;color: rgb(106, 171, 115);&quot;&gt;&quot;OK clicked!&quot; &lt;/span&gt;}&lt;br&gt;    )&lt;br&gt;}&lt;br&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;class &lt;/span&gt;XxxxViewModel&lt;span style=&quot;color: rgb(111, 115, 122);&quot;&gt;() &lt;/span&gt;: ViewModel() {&lt;br&gt;    &lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;private val &lt;/span&gt;&lt;span style=&quot;color: rgb(199, 125, 187);&quot;&gt;_ok &lt;/span&gt;= &lt;span style=&quot;font-style: italic;&quot;&gt;MutableStateFlow&lt;/span&gt;(&lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;false&lt;/span&gt;)&lt;br&gt;    &lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;val &lt;/span&gt;&lt;span style=&quot;color: rgb(199, 125, 187);&quot;&gt;ok&lt;/span&gt;: StateFlow&amp;lt;Boolean&amp;gt; = &lt;span style=&quot;color: rgb(199, 125, 187);&quot;&gt;_ok&lt;/span&gt;.&lt;span style=&quot;color: rgb(87, 170, 247); font-style: italic;&quot;&gt;asStateFlow&lt;/span&gt;()&lt;br&gt;&lt;br&gt;    &lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;fun &lt;/span&gt;&lt;span style=&quot;color: rgb(86, 168, 245);&quot;&gt;notifyOk&lt;/span&gt;() {&lt;br&gt;        &lt;span style=&quot;color: rgb(199, 125, 187);&quot;&gt;_ok&lt;/span&gt;.&lt;span style=&quot;color: rgb(199, 125, 187);&quot;&gt;value &lt;/span&gt;= &lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;true&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(207, 142, 109);&quot;&gt;    &lt;/span&gt;}&lt;br&gt;}&lt;/pre&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;strokeColor=#000000;fillColor=#000000;verticalAlign=top;" vertex="1" parent="1">
